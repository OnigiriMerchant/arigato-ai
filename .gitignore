# ============================================================
# .gitignore for Arigato AI — iOS / Swift / Xcode
# ============================================================

# --- macOS noise ---
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*

# --- Xcode build artifacts (HUGE — never commit) ---
build/
DerivedData/
*.xcodeproj/xcuserdata/
*.xcworkspace/xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/
*.xcuserstate
*.moved-aside

# --- Swift Package Manager ---
.swiftpm/
.build/

# --- CocoaPods (we don't use these but future-proofing) ---
Pods/
# Allow Package.resolved for reproducible builds (SPM lock file) —
# anchor to repo root so embedded project.xcworkspace stays tracked
/*.xcworkspace

# --- Carthage ---
Carthage/Build/
Carthage/Checkouts/

# --- Fastlane ---
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output

# --- Provisioning, signing, secrets ---
*.mobileprovision
*.p12
*.cer
*.certSigningRequest
.env
.env.local
secrets.json
GoogleService-Info.plist

# --- LEAP API key, Anthropic API key, anything sensitive ---
*.apikey
.api-keys/

# --- Model files (bundled via Git LFS or downloaded on demand) ---
# Whisper models can be 600MB+, LFM2 ~250MB+ — most don't belong in Git.
# Exception: the bundled LFM2 GGUF under ArigatoAI/Resources/Models/ is
# Git LFS-tracked (see .gitattributes and CLAUDE.md ## Setup).
*.gguf
*.bundle
*.mlmodelc
Models/*.gguf
Models/*.bundle
!ArigatoAI/Resources/Models/*.gguf
# Exception: the bundled WhisperKit model under ArigatoAI/Resources/WhisperModels/
# is Git LFS-tracked (large weights; see .gitattributes and CLAUDE.md ## Setup).
# The `**` re-includes the *.mlmodelc package directories themselves (excluded
# by `*.mlmodelc` above) so git descends into them — without it the weights
# inside stay ignored.
!ArigatoAI/Resources/WhisperModels/**

# --- IDE noise ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Claude Code session artifacts (keep config, exclude session data) ---
.claude/sessions/
.claude/cache/
.claude/logs/

# --- Logs ---
*.log

# Personal local Claude Code settings (hooks, overrides) — never commit
.claude/settings.local.json

# XcodeBuildMCP local cache
.xcodebuildmcp/
.phase7-preview/
